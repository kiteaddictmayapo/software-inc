{
  "name": "software-inc-app",
  "version": "0.1.0",
  "description": "App de escritorio (Windows 11) para la gestión de una escuela de deportes acuáticos. Reemplaza el Excel 'software inc.xlsx'.",
  "author": "Software Inc",
  "license": "UNLICENSED",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "demo": "vite --config vite.demo.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "tsx --test test/*.test.ts",
    "import:cli": "tsx src/main/services/importCli.ts",
    "postinstall": "electron-builder install-app-deps",
    "package:win": "electron-vite build && electron-builder --win --x64",
    "release:win": "electron-vite build && electron-builder --win --x64 --publish always",
    "package:portable": "electron-vite build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "nodemailer": "^6.9.15",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "chart.js": "^4.4.4",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
